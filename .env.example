# ─── ALL OPTIONAL ───────────────────────────────────────────────
# The digest runs 100% free with NONE of these set — it just writes
# the digest to ./output/ and uses yfinance for prices. Add keys to
# unlock email delivery, congressional data, and SMS nudges.

# Email delivery (free tier: 3,000 emails/month) — https://resend.com
RESEND_API_KEY=
DIGEST_EMAIL_FROM=digest@yourdomain.com
DIGEST_EMAIL_TO=you@example.com

# Congressional trades + better prices (free tier) — https://finnhub.io
# NOTE: Finnhub's congressional-trading endpoint is premium on most accounts as
# of 2024. If you see 403s in the logs, fall back to FMP below.
FINNHUB_API_KEY=

# Recommended free congressional source (250 calls/day) — https://financialmodelingprep.com
FMP_API_KEY=

# SMS nudge on important days (you already have Telnyx; ~$0.004/msg)
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=
TELNYX_TO_NUMBER=

# SEC EDGAR requires a descriptive User-Agent with your contact info
EDGAR_UA=YourName your-email@example.com
